# Bharat Kavach — Environment Configuration Example
# -------------------------------------------------------
# Copy this file to .env and populate the values before
# running the backend server:
#
#   cp .env.example .env
#
# Then edit .env and replace placeholder values with your
# actual credentials. Never commit the populated .env file.
# -------------------------------------------------------

# Required for Gemini 1.5 Flash AI features (transcript analysis,
# document forensics, currency verification, and legal RAG).
GOOGLE_API_KEY=your_google_api_key_here
